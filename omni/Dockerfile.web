FROM node:20-alpine AS builder

WORKDIR /app

# Install pnpm globally
RUN npm install -g pnpm

# Copy root configurations
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.json ./

# Copy packages and apps directories
COPY packages/shared ./packages/shared
COPY apps/web ./apps/web

# Install dependencies and build shared + web frontend
RUN pnpm install --frozen-lockfile
RUN pnpm --filter shared build
RUN pnpm --filter web build

FROM node:20-alpine AS runner

WORKDIR /app

# Install next globally or copy the node modules / standalone build
# To keep deployment simple and robust, we can run Next.js server with dependencies copied
COPY --from=builder /app/package.json ./
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/packages/shared/dist ./packages/shared/dist
COPY --from=builder /app/packages/shared/package.json ./packages/shared/package.json
COPY --from=builder /app/apps/web ./apps/web

EXPOSE 3000

ENV PORT=3000
ENV NODE_ENV=production

WORKDIR /app/apps/web
CMD ["npx", "next", "start", "-p", "3000"]
